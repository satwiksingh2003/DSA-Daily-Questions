class Solution {
    public int alternateDigitSum(int n) {
        int sum = 0;
        int sign = 1;  // start from rightmost digit
        while (n > 0) {
            sum += sign * (n % 10);
            sign *= -1;
            n /= 10;
        }
        // If number of digits is even, flip result
        return -sign * sum;
    }
}
