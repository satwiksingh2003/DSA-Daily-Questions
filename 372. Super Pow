class Solution {
    static final int MOD = 1337;
    public int superPow(int a, int[] b) {
        int result = 1;
        a = a % MOD;
        for (int digit : b) {
            result = pow(result, 10) * pow(a, digit) % MOD;
        }
        return result;
    }
    // Fast modular exponentiation
    private int pow(int a, int b) {
        int result = 1;
        a %= MOD;
        while (b > 0) {
            if ((b & 1) == 1) {
                result = result * a % MOD;
            }
            a = a * a % MOD;
            b >>= 1;
        }
        return result;
    }
}
