class Solution {
    public boolean checkPerfectNumber(int num) {
        if (num <= 1) return false;
        int sum = 1; // 1 is always a divisor
        for (int i = 2; i * i <= num; i++) {
            if (num % i == 0) {
                sum += i;  
                if (i != num / i) { // avoid duplicate
                    sum += num / i;
                }
            }
        }
        return sum == num;
    }
}
