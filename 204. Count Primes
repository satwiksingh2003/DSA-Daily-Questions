class Solution {
    public int countPrimes(int n) {
        if (n <= 2) return 0;
        boolean[] prime = new boolean[n]; // Sieve of Eratosthenes
        for (int i = 2; i < n; i++) {
            prime[i] = true;
        }
        for (int i = 3; i * i < n; i += 2) {
            if (prime[i]) {
                for (int j = i * i; j < n; j += 2 * i) {
                    prime[j] = false;
                }
            }
        }
        int count = 1; // counting prime number 2
        for (int i = 3; i < n; i += 2) {
            if (prime[i]) count++;
        }
        return count;
    }
}
